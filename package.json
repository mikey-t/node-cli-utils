{
  "name": "@mikeyt23/node-cli-utils",
  "version": "2.1.0",
  "description": "Stuff I wish was in the Node.js standard library - along with other misc utility functions",
  "author": "Mike Thompson",
  "license": "MIT",
  "homepage": "https://github.com/mikey-t/node-cli-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikey-t/node-cli-utils.git"
  },
  "type": "module",
  "scripts": {
    "watch": "tsc -w --p tsconfig.esm.json",
    "watch:cjs": "tsc -w --p tsconfig.cjs.json"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./dockerUtils": {
      "import": {
        "types": "./dist/esm/dockerUtils.d.ts",
        "default": "./dist/esm/dockerUtils.js"
      },
      "require": {
        "types": "./dist/cjs/dockerUtils.d.ts",
        "default": "./dist/cjs/dockerUtils.js"
      }
    },
    "./certUtils": {
      "import": {
        "types": "./dist/esm/certUtils.d.ts",
        "default": "./dist/esm/certUtils.js"
      },
      "require": {
        "types": "./dist/cjs/certUtils.d.ts",
        "default": "./dist/cjs/certUtils.js"
      }
    },
    "./dotnetUtils": {
      "import": {
        "types": "./dist/esm/dotnetUtils.d.ts",
        "default": "./dist/esm/dotnetUtils.js"
      },
      "require": {
        "types": "./dist/cjs/dotnetUtils.d.ts",
        "default": "./dist/cjs/dotnetUtils.js"
      }
    },
    "./colors": {
      "import": {
        "types": "./dist/esm/colors.d.ts",
        "default": "./dist/esm/colors.js"
      },
      "require": {
        "types": "./dist/cjs/colors.d.ts",
        "default": "./dist/cjs/colors.js"
      }
    },
    "./DependencyChecker": {
      "import": {
        "types": "./dist/esm/DependencyChecker.d.ts",
        "default": "./dist/esm/DependencyChecker.js"
      },
      "require": {
        "types": "./dist/cjs/DependencyChecker.d.ts",
        "default": "./dist/cjs/DependencyChecker.js"
      }
    },
    "./hostFileUtils": {
      "import": {
        "types": "./dist/esm/hostFileUtils.d.ts",
        "default": "./dist/esm/hostFileUtils.js"
      },
      "require": {
        "types": "./dist/cjs/hostFileUtils.d.ts",
        "default": "./dist/cjs/hostFileUtils.js"
      }
    },
    "./parallel": {
      "import": {
        "types": "./dist/esm/parallel.d.ts",
        "default": "./dist/esm/parallel.js"
      },
      "require": {
        "types": "./dist/cjs/parallel.d.ts",
        "default": "./dist/cjs/parallel.js"
      }
    },
    "./testUtils": {
      "import": {
        "types": "./dist/esm/testUtils.d.ts",
        "default": "./dist/esm/testUtils.js"
      },
      "require": {
        "types": "./dist/cjs/testUtils.d.ts",
        "default": "./dist/cjs/testUtils.js"
      }
    }
  },
  "main": "./dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "package.json",
    "dist/",
    "readme.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.33.0",
      "onFail": "ignore"
    },
    "runtime": {
      "name": "node",
      "version": "24.14.0"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "c8": "^11.0.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "swig-cli": "^1.0.5",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "~6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
