{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "declaration": true,
    "declarationMap": true,
    "inlineSourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist/cjs",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ES2018",
      "ES2021.String",
      "ES2022"
    ],
    "types": [
      "node"
    ],
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    ".vscode",
    "coverage",
    "dist",
    "node_modules",
    "test",
    "scratch"
  ]
}
